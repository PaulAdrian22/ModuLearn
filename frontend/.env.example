# Copy to .env.local and fill in values from your Supabase project
# (Project Settings → API)
REACT_APP_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
REACT_APP_SUPABASE_ANON_KEY=eyJhbGciOi... your anon public key ...

# Modal-hosted pyBKT batch-update endpoint. Run `modal deploy modal_app.py`
# in python_services/ and paste the printed URL here.
REACT_APP_BKT_BATCH_UPDATE_URL=https://YOUR-WORKSPACE--modulearn-bkt-batch-update.modal.run
