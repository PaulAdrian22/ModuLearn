# Server Configuration
PORT=5000
NODE_ENV=development

# Database Configuration
DB_HOST=localhost
DB_USER=modulearn_user
DB_PASSWORD=ModulearnSecurePass2025!
DB_NAME=modulearn_db
DB_PORT=3306

# JWT Configuration
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production_min_32_chars
JWT_EXPIRE=24h
JWT_REFRESH_SECRET=your_super_secret_refresh_key_change_this_in_production_min_32_chars
JWT_REFRESH_EXPIRE=7d

# CORS Configuration
CORS_ORIGIN=http://localhost:3000

# BKT Default Parameters
BKT_DEFAULT_PKNOWN=0.1000
BKT_DEFAULT_PLEARN=0.3000
BKT_DEFAULT_PSLIP=0.1000
BKT_DEFAULT_PGUESS=0.2500
BKT_MASTERY_THRESHOLD=0.9500

# File Upload Configuration
MAX_FILE_SIZE=10485760
UPLOAD_PATH=./uploads
STORAGE_PROVIDER=local

# Azure Blob Storage (used when STORAGE_PROVIDER=azure)
AZURE_STORAGE_CONTAINER_NAME=modulearn-assets
AZURE_STORAGE_CONNECTION_STRING=
AZURE_STORAGE_ACCOUNT_NAME=
AZURE_STORAGE_ACCOUNT_KEY=
AZURE_STORAGE_PUBLIC_BASE_URL=

# Pagination
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100

# Session
SESSION_SECRET=your_session_secret_change_this_in_production
SESSION_EXPIRE=3600000

# Email Configuration (Optional - for future features)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASSWORD=your_email_password
EMAIL_FROM=noreply@modulearn.com

# Application
APP_NAME=MODULEARN
APP_URL=http://localhost:5000
CLIENT_URL=http://localhost:3000

# Security
BCRYPT_ROUNDS=10
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_TIME=900000

# Logging
LOG_LEVEL=debug
LOG_FILE=./logs/app.log
