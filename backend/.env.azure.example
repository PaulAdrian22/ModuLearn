# Backend runtime
NODE_ENV=production
PORT=8080

# Database (Azure MySQL)
DB_HOST=
DB_USER=
DB_PASSWORD=
DB_NAME=
DB_PORT=3306

# Auth
JWT_SECRET=
JWT_REFRESH_SECRET=
JWT_EXPIRE=24h
JWT_REFRESH_EXPIRE=7d

# CORS
CORS_ORIGIN=

# Storage provider
STORAGE_PROVIDER=azure
AZURE_STORAGE_CONTAINER_NAME=modulearn-assets

# Option A: recommended (single value)
AZURE_STORAGE_CONNECTION_STRING=

# Option B: account credentials (use when connection string is unavailable)
AZURE_STORAGE_ACCOUNT_NAME=
AZURE_STORAGE_ACCOUNT_KEY=

# Optional custom public URL base (for CDN/custom domain)
AZURE_STORAGE_PUBLIC_BASE_URL=
