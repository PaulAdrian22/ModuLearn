{
  "name": "modulearn-backend",
  "version": "1.0.0",
  "description": "Backend API for MODULEARN - Web-Based Individualized Learning Platform",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "db:test": "node test_db_connection.js",
    "import:lesson1": "node import_lesson1_text.js",
    "import:lesson2": "node import_lesson2_text.js",
    "import:lesson3": "node import_lesson3_text.js",
    "import:lesson4": "node import_lesson4_text.js",
    "import:lesson5": "node import_lesson5_text.js",
    "import:lesson6": "node import_lesson6_text.js",
    "import:lesson7": "node import_lesson7_text.js",
    "seed:simulations": "node seed_simulation_activities.js",
    "verify:simulations": "node verify_simulation_assets.js",
    "sync:remote:api": "node sync_local_to_remote_api.js",
    "migrate:media:azure": "node migrate_media_to_azure_blob.js",
    "migrate:media:azure:dry": "node migrate_media_to_azure_blob.js --dry-run"
  },
  "keywords": [
    "education",
    "bayesian",
    "adaptive-learning",
    "api"
  ],
  "author": "Paula",
  "license": "ISC",
  "dependencies": {
    "@azure/storage-blob": "^12.31.0",
    "bcryptjs": "^2.4.3",
    "cheerio": "^1.2.0",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-validator": "^7.0.1",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "mammoth": "^1.12.0",
    "morgan": "^1.10.0",
    "multer": "^2.0.2",
    "mysql2": "^3.6.5",
    "serverless-http": "^3.2.0",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "nodemon": "^3.0.2",
    "supertest": "^6.3.3"
  },
  "engines": {
    "node": ">=16.0.0",
    "npm": ">=8.0.0"
  }
}
